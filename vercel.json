{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/webapp/static/index.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/webapp/static/$1"
    },
    {
      "source": "/examples/(.*)",
      "destination": "/webapp/static/examples/$1"
    }
  ]
}
